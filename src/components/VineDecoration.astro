---
// Decorative vine with leaves that sways based on scroll position
---

<svg
	class="pointer-events-none absolute right-0 top-0 z-10 w-48 opacity-80 sm:w-56"
	viewBox="0 0 220 500"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
	aria-hidden="true"
	id="vine-decoration"
>
	<defs>
		<!-- Gradient for leaf depth -->
		<linearGradient id="leaf-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
			<stop offset="0%" style="stop-color:rgb(var(--theme-accent));stop-opacity:0.7" />
			<stop offset="100%" style="stop-color:rgb(var(--theme-accent));stop-opacity:0.4" />
		</linearGradient>
	</defs>

	<g id="vine-group" style="transform-origin: 190px 20px;">
		<!-- Main vine stem with organic curves -->
		<path
			d="M 190 0 C 188 15, 185 30, 182 50 C 180 70, 175 90, 170 110 C 165 130, 162 150, 158 170 C 155 190, 152 210, 148 230 C 145 250, 143 270, 140 290 C 138 310, 136 330, 134 350 C 132 370, 131 390, 130 410 C 129 430, 128 450, 127 470"
			stroke="rgb(var(--theme-accent))"
			stroke-width="3"
			stroke-linecap="round"
			fill="none"
			opacity="0.65"
		/>

		<!-- Vine secondary strands for depth -->
		<path
			d="M 182 50 Q 178 60, 175 70"
			stroke="rgb(var(--theme-accent))"
			stroke-width="1.5"
			stroke-linecap="round"
			fill="none"
			opacity="0.4"
		/>
		<path
			d="M 158 170 Q 154 180, 150 190"
			stroke="rgb(var(--theme-accent))"
			stroke-width="1.5"
			stroke-linecap="round"
			fill="none"
			opacity="0.4"
		/>
		<path
			d="M 140 290 Q 136 300, 132 310"
			stroke="rgb(var(--theme-accent))"
			stroke-width="1.5"
			stroke-linecap="round"
			fill="none"
			opacity="0.4"
		/>

		<!-- Detailed leaves with realistic shapes -->
		<!-- Leaf 1 - top right -->
		<g transform="translate(185, 45)">
			<path
				d="M 0 0 Q 8 -2, 12 -6 Q 14 -3, 12 2 Q 8 6, 0 8 Q -3 4, 0 0"
				fill="url(#leaf-gradient)"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.8"
			/>
			<line
				x1="0"
				y1="0"
				x2="10"
				y2="-2"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.6"
			/>
		</g>

		<!-- Leaf 2 - left side -->
		<g transform="translate(172, 85) rotate(-30)">
			<path
				d="M 0 0 Q -6 3, -10 8 Q -8 12, -2 12 Q 4 8, 4 0 Q 0 -2, 0 0"
				fill="url(#leaf-gradient)"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.75"
			/>
			<line
				x1="0"
				y1="0"
				x2="-6"
				y2="6"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.5"
			/>
		</g>

		<!-- Leaf 3 - right side large -->
		<g transform="translate(178, 130) rotate(25)">
			<path
				d="M 0 0 Q 10 -3, 16 -8 Q 18 -3, 16 4 Q 10 10, 0 12 Q -4 6, 0 0"
				fill="url(#leaf-gradient)"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.85"
			/>
			<line
				x1="0"
				y1="0"
				x2="12"
				y2="-2"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.6"
			/>
		</g>

		<!-- Leaf 4 - left side -->
		<g transform="translate(160, 175) rotate(-45)">
			<path
				d="M 0 0 Q -7 2, -11 7 Q -9 11, -3 11 Q 3 7, 3 0 Q 0 -2, 0 0"
				fill="url(#leaf-gradient)"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.7"
			/>
			<line
				x1="0"
				y1="0"
				x2="-7"
				y2="5"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.5"
			/>
		</g>

		<!-- Leaf 5 - right side -->
		<g transform="translate(165, 220) rotate(15)">
			<path
				d="M 0 0 Q 9 -2, 14 -7 Q 16 -2, 14 3 Q 9 8, 0 10 Q -3 5, 0 0"
				fill="url(#leaf-gradient)"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.8"
			/>
			<line
				x1="0"
				y1="0"
				x2="11"
				y2="-3"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.6"
			/>
		</g>

		<!-- Leaf 6 - left side large -->
		<g transform="translate(145, 265) rotate(-50)">
			<path
				d="M 0 0 Q -8 3, -13 9 Q -10 14, -2 14 Q 5 9, 5 0 Q 0 -3, 0 0"
				fill="url(#leaf-gradient)"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.85"
			/>
			<line
				x1="0"
				y1="0"
				x2="-8"
				y2="7"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.6"
			/>
		</g>

		<!-- Leaf 7 - right side -->
		<g transform="translate(152, 315) rotate(20)">
			<path
				d="M 0 0 Q 8 -2, 12 -6 Q 14 -2, 12 3 Q 8 7, 0 9 Q -3 4, 0 0"
				fill="url(#leaf-gradient)"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.75"
			/>
			<line
				x1="0"
				y1="0"
				x2="10"
				y2="-2"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.5"
			/>
		</g>

		<!-- Leaf 8 - left side -->
		<g transform="translate(138, 360) rotate(-40)">
			<path
				d="M 0 0 Q -7 2, -11 7 Q -9 11, -3 11 Q 3 7, 3 0 Q 0 -2, 0 0"
				fill="url(#leaf-gradient)"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.7"
			/>
			<line
				x1="0"
				y1="0"
				x2="-7"
				y2="5"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.5"
			/>
		</g>

		<!-- Leaf 9 - right side -->
		<g transform="translate(145, 410) rotate(30)">
			<path
				d="M 0 0 Q 9 -2, 13 -6 Q 15 -2, 13 3 Q 9 7, 0 9 Q -3 4, 0 0"
				fill="url(#leaf-gradient)"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.8"
			/>
			<line
				x1="0"
				y1="0"
				x2="10"
				y2="-2"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.6"
			/>
		</g>

		<!-- Leaf 10 - bottom left -->
		<g transform="translate(132, 455) rotate(-35)">
			<path
				d="M 0 0 Q -6 2, -9 6 Q -7 9, -2 9 Q 3 6, 3 0 Q 0 -2, 0 0"
				fill="url(#leaf-gradient)"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.75"
			/>
			<line
				x1="0"
				y1="0"
				x2="-6"
				y2="4"
				stroke="rgb(var(--theme-accent))"
				stroke-width="0.5"
				opacity="0.5"
			/>
		</g>

		<!-- Small buds for extra detail -->
		<circle cx="175" cy="70" r="2" fill="rgb(var(--theme-accent))" opacity="0.6" />
		<circle cx="162" cy="155" r="1.5" fill="rgb(var(--theme-accent))" opacity="0.5" />
		<circle cx="148" cy="245" r="2" fill="rgb(var(--theme-accent))" opacity="0.6" />
		<circle cx="141" cy="335" r="1.5" fill="rgb(var(--theme-accent))" opacity="0.5" />
	</g>
</svg>

<script is:inline>
	(function () {
		const vineGroup = document.getElementById("vine-group");
		if (!vineGroup) return;

		let ticking = false;

		function updateVine() {
			const scrollY = window.scrollY || window.pageYOffset;

			// More pronounced rotation (3 degrees) with slower frequency
			const rotation = Math.sin(scrollY * 0.002) * 3;

			// Horizontal translation for natural sway
			const translateX = Math.sin(scrollY * 0.0015) * 5;

			// Slight vertical movement
			const translateY = Math.cos(scrollY * 0.001) * 2;

			vineGroup.style.transform = `rotate(${rotation}deg) translateX(${translateX}px) translateY(${translateY}px)`;
			ticking = false;
		}

		// Initial call
		updateVine();

		window.addEventListener(
			"scroll",
			function () {
				if (!ticking) {
					window.requestAnimationFrame(updateVine);
					ticking = true;
				}
			},
			{ passive: true },
		);
	})();
</script>
